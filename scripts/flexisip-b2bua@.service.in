[Unit]
Description=Flexisip Back to back user agent server - %i instance
Documentation=https://www.linphone.org/en/flexisip-sip-server/
Wants=network-online.target
After=syslog.target network.service network.target network-online.target redis.service

[Service]
UMask=0027
Type=notify
ExecStart=/opt/belledonne-communications/bin/flexisip --server b2b2ua --disable-stdout --syslog --pidfile /var/run/flexisip-b2b2ua/%i.pid -c /etc/flexisip/%i.conf
Restart=on-failure
WatchdogSec=10s
RestartForceExitStatus=5
RestartSec=1s

[Install]
WantedBy=multi-user.target
