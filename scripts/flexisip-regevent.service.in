[Unit]
Description=Flexisip RegEvent server
Documentation=https://www.linphone.org/en/flexisip-sip-server/
Wants=network-online.target
After=syslog.target network.service network.target network-online.target redis.service

[Service]
UMask=0027
Type=notify
ExecStart=@bindir@/flexisip --server regevent --disable-stdout --syslog --pidfile /var/run/flexisip-regevent.pid
Restart=on-failure
WatchdogSec=10s
RestartForceExitStatus=5
RestartSec=1s

[Install]
WantedBy=multi-user.target
