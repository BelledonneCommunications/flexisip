[Unit]
Description=Flexisip Voicemail server
Documentation=https://www.linphone.org/en/flexisip-sip-server/
Wants=network-online.target
After=syslog.target network.service network.target network-online.target

[Service]
Type=notify
ExecStart=@bindir@/flexisip --server voicemail --disable-stdout --syslog --pidfile /var/run/flexisip-voicemail.pid
Restart=on-failure
WatchdogSec=10s
RestartForceExitStatus=5
RestartSec=1s

[Install]
WantedBy=multi-user.target
